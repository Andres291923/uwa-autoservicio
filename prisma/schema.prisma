generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Category {
  id                Int       @id @default(autoincrement())
  name              String
  slug              String    @unique
  order             Int       @default(0)
  active            Boolean   @default(true)
  channelVisibility String    @default("all")
  products          Product[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
}

model Product {
  stockItems        StockItem[]
  id                Int         @id @default(autoincrement())
  name              String
  description       String?
  price             Int
  imageUrl          String?
  active            Boolean     @default(true)
  channelVisibility String      @default("all")
  order             Int         @default(0)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  modifierGroups ProductModifierGroup[]
  orderItems     OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ModifierTemplate {
  id     Int     @id @default(autoincrement())
  name   String
  order  Int     @default(0)
  active Boolean @default(true)

  channelVisibility String                 @default("all")
  options           ModifierOption[]
  products          ProductModifierGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ModifierOption {
  stockItems        StockItem[]
  id                Int         @id @default(autoincrement())
  name              String
  price             Int         @default(0)
  imageUrl          String?
  active            Boolean     @default(true)
  channelVisibility String      @default("all")
  order             Int         @default(0)

  templateId Int
  template   ModifierTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  orderItemModifiers OrderItemModifier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ProductModifierGroup {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  templateId Int
  template   ModifierTemplate @relation(fields: [templateId], references: [id])

  min      Int     @default(0)
  max      Int     @default(1)
  required Boolean @default(false)
  order    Int     @default(0)
  active   Boolean @default(true)

  channelVisibility String   @default("all")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@unique([productId, templateId])
}

model Order {
  stockMovements     StockMovement[]
  id                 Int             @id @default(autoincrement())
  orderNumber        Int
  status             String          @default("pending")
  total              Int             @default(0)
  customerName       String?
  customerComment    String?
  customerId         Int?
  companyCustomerId  Int?
  walletAmountUsed   Int             @default(0)
  cashbackEarned     Int             @default(0)
  tipAmount          Int             @default(0)
  subtotalAmount     Int             @default(0)
  discountAmount     Int             @default(0)
  discountPercent    Int             @default(0)
  discountCouponCode String?
  totemCode          String?
  paymentMethod      String          @default("unknown")
  printStatus       String          @default("pending")
  printedAt         DateTime?
  printCount        Int             @default(0)
  lastPrintError    String?
  claimedAt         DateTime?
  printAgentId      String?

  orderSource     String           @default("totem")
  fulfillmentType String           @default("immediate")
  scheduledFor    DateTime?
  items           OrderItem[]
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  companyCustomer CompanyCustomer? @relation(fields: [companyCustomerId], references: [id], onDelete: SetNull)

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  businessSettings   BusinessSettings? @relation(fields: [businessSettingsId], references: [id])
  businessSettingsId Int?
  cashbackRule       CashbackRule?     @relation(fields: [cashbackRuleId], references: [id])
  cashbackRuleId     Int?
}

model OrderItem {
  id        Int @id @default(autoincrement())
  quantity  Int @default(1)
  unitPrice Int
  total     Int

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  modifiers OrderItemModifier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model OrderItemModifier {
  id Int @id @default(autoincrement())

  orderItemId Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  optionId Int
  option   ModifierOption @relation(fields: [optionId], references: [id])

  price Int @default(0)

  createdAt DateTime @default(now())
}

model BusinessSettings {
  id                Int     @id
  businessName      String  @default("Mi negocio")
  logoUrl           String?
  idleBackgroundUrl String?
  primaryColor      String  @default("#10B557")
  kioskSubtitle     String  @default("Autoservicio")
  kioskTitle        String  @default("Elige tus productos")

  tipsEnabled Boolean  @default(false)
  tipPercent  Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders       Order[]
  openingHours StoreOpeningHour[]
}

model Customer {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  passwordHash      String?
  pinHash           String?
  pinAttempts       Int       @default(0)
  pinLockedUntil    DateTime?
  active            Boolean   @default(true)
  channelVisibility String    @default("all")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders Order[]

  openingHours       StoreOpeningHour[]
  walletTransactions WalletTransaction[]
  totemSessions      TotemSession[]
}

model WalletTransaction {
  id         Int       @id @default(autoincrement())
  customerId Int
  type       String
  amount     Int
  reason     String
  source     String    @default("manual")
  orderId    Int?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CashbackRule {
  id                    Int       @id @default(autoincrement())
  name                  String
  active                Boolean   @default(false)
  cashbackPercent       Float     @default(0)
  minPurchase           Int       @default(0)
  maxCashback           Int       @default(0)
  allowedPaymentMethods String    @default("all")
  dailyStartTime        String    @default("")
  dailyEndTime          String    @default("")
  includedCategoryIds   String    @default("all")
  excludedProductIds    String    @default("")
  validityDays          Int       @default(0)
  commercialText        String    @default("")
  priority              Int       @default(0)
  startDate             DateTime?
  endDate               DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  orders       Order[]
  openingHours StoreOpeningHour[]
}

model StoreOpeningHour {
  id                 Int              @id @default(autoincrement())
  businessSettingsId Int
  businessSettings   BusinessSettings @relation(fields: [businessSettingsId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  enabled   Boolean @default(true)
  openTime  String  @default("10:00")
  closeTime String  @default("18:00")

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer?     @relation(fields: [customerId], references: [id])
  customerId     Int?
  cashbackRule   CashbackRule? @relation(fields: [cashbackRuleId], references: [id])
  cashbackRuleId Int?

  @@unique([businessSettingsId, dayOfWeek])
}

model DiscountCoupon {
  id                Int      @id @default(autoincrement())
  name              String
  code              String   @unique
  percent           Int      @default(10)
  active            Boolean  @default(true)
  channelVisibility String   @default("all")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  permissions  String   @default("")
  active       Boolean  @default(true)
  isOwner      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InventoryCategory {
  id        Int      @id @default(autoincrement())
  name      String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories InventorySubcategory[]
  items         InventoryItem[]
}

model InventorySubcategory {
  id         Int      @id @default(autoincrement())
  categoryId Int
  name       String
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    InventoryItem[]
}

model InventoryItem {
  id             Int      @id @default(autoincrement())
  categoryId     Int
  subcategoryId  Int?
  name           String
  unit           String   @default("")
  wasteCostPerKg Int      @default(0)
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category     InventoryCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory  InventorySubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  entries      InventoryEntry[]
  wasteEntries InventoryWasteEntry[]
}

model InventoryEntry {
  id        Int      @id @default(autoincrement())
  entryDate DateTime
  itemId    Int
  quantity  Float    @default(0)
  comment   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([entryDate, itemId])
}

model TotemSession {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  status     String   @default("waiting")
  customerId Int?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
}

model InventoryWasteEntry {
  id            Int      @id @default(autoincrement())
  entryDate     DateTime
  itemId        Int?
  productName   String   @default("")
  quantityGrams Float    @default(0)
  amount        Int      @default(0)
  comment       String   @default("")
  source        String   @default("manual")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  item InventoryItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

model PurchaseImport {
  id           Int      @id @default(autoincrement())
  fileName     String   @default("")
  status       String   @default("completed")
  totalRows    Int      @default(0)
  importedRows Int      @default(0)
  skippedRows  Int      @default(0)
  createdAt    DateTime @default(now())

  invoices PurchaseInvoice[]
}

model PurchaseInvoice {
  id           Int      @id @default(autoincrement())
  importId     Int?
  issueDate    DateTime
  supplierRut  String   @default("")
  supplierName String   @default("")
  documentType String   @default("")
  folio        String   @default("")
  netAmount    Int      @default(0)
  exemptAmount Int      @default(0)
  ivaAmount    Int      @default(0)
  totalAmount  Int      @default(0)
  category     String   @default("unclassified")
  note         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  import PurchaseImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([issueDate])
  @@index([category])
  @@index([supplierRut])
}

model CompanyCustomer {
  id           Int      @id @default(autoincrement())
  companyName  String
  rut          String   @unique
  giro         String
  address      String
  contactName  String
  phone        String
  email        String   @unique
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
  invoices CompanyInvoice[]
  walletBalance Int @default(0)
  walletTransactions CompanyWalletTransaction[]
  workers CompanyWorker[]
  workerWalletTransactions CompanyWorkerWalletTransaction[]
}

model CompanyBankSettings {
  id            Int      @id @default(1)
  businessName  String   @default("")
  rut           String   @default("")
  bank          String   @default("")
  accountType   String   @default("")
  accountNumber String   @default("")
  email         String   @default("")
  updatedAt     DateTime @updatedAt
}

model StockItem {
  id Int @id @default(autoincrement())

  name         String
  currentStock Int     @default(0)
  minStock     Int     @default(0)
  active       Boolean @default(true)

  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  modifierOptionId Int?
  modifierOption   ModifierOption? @relation(fields: [modifierOptionId], references: [id], onDelete: SetNull)

  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([modifierOptionId])
}

model StockMovement {
  id Int @id @default(autoincrement())

  stockItemId Int
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  type     String
  quantity Int

  previousStock Int
  newStock      Int

  reason String?

  orderId Int?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([stockItemId])
  @@index([orderId])
}


model CompanyInvoice {
  id                Int      @id @default(autoincrement())
  companyCustomerId Int
  invoiceNumber     String
  invoiceDate       DateTime?
  amount            Int      @default(0)
  fileUrl           String
  fileName          String?
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyCustomer CompanyCustomer @relation(fields: [companyCustomerId], references: [id], onDelete: Cascade)
  walletTransactions CompanyWalletTransaction[]
}


model CompanyWalletTransaction {
  id                Int      @id @default(autoincrement())
  companyCustomerId Int
  invoiceId         Int?
  type              String
  amount            Int
  balanceAfter      Int
  reason            String
  source            String   @default("manual_admin")
  createdBy         String?
  createdAt         DateTime @default(now())

  companyCustomer CompanyCustomer @relation(fields: [companyCustomerId], references: [id], onDelete: Cascade)
  invoice         CompanyInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}


model CompanyWorker {
  id                Int      @id @default(autoincrement())
  companyCustomerId Int
  name              String
  email             String?
  rut               String?
  phone             String?
  active            Boolean  @default(true)
  walletBalance     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyCustomer CompanyCustomer @relation(fields: [companyCustomerId], references: [id], onDelete: Cascade)
  walletTransactions CompanyWorkerWalletTransaction[]
  passwordHash String?
  totemPinHash String?
}


model CompanyWorkerWalletTransaction {
  id                  Int      @id @default(autoincrement())
  companyWorkerId     Int
  companyCustomerId   Int
  type                String
  amount              Int
  workerBalanceAfter  Int
  companyBalanceAfter Int
  reason              String
  source              String   @default("company_assignment")
  createdAt           DateTime @default(now())

  worker          CompanyWorker   @relation(fields: [companyWorkerId], references: [id], onDelete: Cascade)
  companyCustomer CompanyCustomer @relation(fields: [companyCustomerId], references: [id], onDelete: Cascade)
}

model MercadoPagoPaymentIntent {
  id                Int       @id @default(autoincrement())
  publicId          String    @unique
  flow              String
  status            String    @default("created")

  amount            Int       @default(0)

  customerId        Int?
  companyCustomerId Int?
  orderId           Int?

  preferenceId      String?
  initPoint         String?
  sandboxInitPoint  String?
  paymentId         String?

  payloadJson       String

  lastError         String?
  approvedAt        DateTime?
  processedAt       DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([flow])
  @@index([status])
  @@index([customerId])
  @@index([companyCustomerId])
  @@index([paymentId])
}

model MercadoPagoSettings {
  id            Int      @id @default(1)
  enabled       Boolean  @default(false)
  environment   String   @default("test")
  publicKey     String   @default("")
  accessToken   String   @default("")
  webhookSecret String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}







model PasswordResetToken {
  id          Int       @id @default(autoincrement())
  accountType String
  email       String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([accountType, email])
}
