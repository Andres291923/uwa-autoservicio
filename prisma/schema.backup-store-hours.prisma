generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  order     Int       @default(0)
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  price       Int
  imageUrl    String?
  active      Boolean @default(true)
  order       Int     @default(0)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  modifierGroups ProductModifierGroup[]
  orderItems     OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ModifierTemplate {
  id     Int     @id @default(autoincrement())
  name   String
  order  Int     @default(0)
  active Boolean @default(true)

  options  ModifierOption[]
  products ProductModifierGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ModifierOption {
  id       Int     @id @default(autoincrement())
  name     String
  price    Int     @default(0)
  imageUrl String?
  active   Boolean @default(true)
  order    Int     @default(0)

  templateId Int
  template   ModifierTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  orderItemModifiers OrderItemModifier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ProductModifierGroup {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  templateId Int
  template   ModifierTemplate @relation(fields: [templateId], references: [id])

  min      Int     @default(0)
  max      Int     @default(1)
  required Boolean @default(false)
  order    Int     @default(0)
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([productId, templateId])
}

model Order {
  id               Int     @id @default(autoincrement())
  orderNumber      Int
  status           String  @default("pending")
  total            Int     @default(0)
  customerName     String?
  customerId       Int?
  walletAmountUsed Int     @default(0)
  cashbackEarned   Int     @default(0)
  tipAmount        Int     @default(0)
  totemCode        String?
  paymentMethod    String  @default("unknown")

  orderSource     String      @default("totem")
  fulfillmentType String      @default("immediate")
  scheduledFor    DateTime?
  items           OrderItem[]
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  businessSettings   BusinessSettings? @relation(fields: [businessSettingsId], references: [id])
  businessSettingsId Int?
  cashbackRule       CashbackRule?     @relation(fields: [cashbackRuleId], references: [id])
  cashbackRuleId     Int?
}

model OrderItem {
  id        Int @id @default(autoincrement())
  quantity  Int @default(1)
  unitPrice Int
  total     Int

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  modifiers OrderItemModifier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model OrderItemModifier {
  id Int @id @default(autoincrement())

  orderItemId Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  optionId Int
  option   ModifierOption @relation(fields: [optionId], references: [id])

  price Int @default(0)

  createdAt DateTime @default(now())
}

model BusinessSettings {
  id                Int     @id
  businessName      String  @default("Mi negocio")
  logoUrl           String?
  idleBackgroundUrl String?
  primaryColor      String  @default("#10B557")
  kioskSubtitle     String  @default("Autoservicio")
  kioskTitle        String  @default("Elige tus productos")

  tipsEnabled Boolean  @default(false)
  tipPercent  Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
}

model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]

  walletTransactions WalletTransaction[]
}

model WalletTransaction {
  id         Int       @id @default(autoincrement())
  customerId Int
  type       String
  amount     Int
  reason     String
  orderId    Int?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CashbackRule {
  id                    Int       @id @default(autoincrement())
  name                  String
  active                Boolean   @default(false)
  cashbackPercent       Float     @default(0)
  minPurchase           Int       @default(0)
  maxCashback           Int       @default(0)
  allowedPaymentMethods String    @default("all")
  includedCategoryIds   String    @default("all")
  excludedProductIds    String    @default("")
  validityDays          Int       @default(0)
  commercialText        String    @default("")
  priority              Int       @default(0)
  startDate             DateTime?
  endDate               DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  orders Order[]
}
