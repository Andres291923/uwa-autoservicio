"use client";

import { useEffect, useMemo, useState } from "react";

type Company = {
  id: number;
  companyName: string;
  rut: string;
  giro: string;
  address: string;
  contactName: string;
  phone: string;
  email: string;
  active: boolean;
  orderCount: number;
  weeklyTotal: number;
  monthlyTotal: number;
  totalPurchased: number;
  lastOrder: {
    orderNumber: number;
    total: number;
    status: string;
    paymentMethod: string;
    scheduledFor: string | null;
    createdAt: string;
  } | null;
};

type BankSettings = {
  businessName: string;
  rut: string;
  bank: string;
  accountType: string;
  accountNumber: string;
  email: string;
};

type CompanyHistory = {
  company: {
    id: number;
    companyName: string;
    rut: string;
    giro: string;
    address: string;
    contactName: string;
    phone: string;
    email: string;
  };
  summary: {
    rangeOrdersCount: number;
    rangeTotal: number;
    ordersCount: number;
    weeklyOrdersCount: number;
    monthlyOrdersCount: number;
    weeklyTotal: number;
    monthlyTotal: number;
    totalHistorical: number;
    averageTicket: number;
    lastOrder: any | null;
    startDate: string;
    endDate: string;
  };
  orders: {
    id: number;
    orderNumber: number;
    createdAt: string;
    scheduledFor: string | null;
    customerName: string;
    status: string;
    paymentMethod: string;
    orderSource: string;
    subtotalAmount: number;
    walletAmountUsed: number;
    discountAmount: number;
    tipAmount: number;
    totalPaid: number;
    items: {
      id: number;
      productName: string;
      categoryName: string;
      quantity: number;
      unitPrice: number;
      total: number;
      modifiers: {
        groupName: string;
        optionName: string;
        price: number;
      }[];
    }[];
  }[];
};

function formatPrice(value: number) {
  return new Intl.NumberFormat("es-CL", {
    style: "currency",
    currency: "CLP",
    maximumFractionDigits: 0,
  }).format(value || 0);
}

function formatDate(value: string | null) {
  if (!value) return "-";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleString("es-CL");
}

function formatPaymentMethod(value: string) {
  if (value === "bank_transfer") return "Transferencia";
  if (value === "debit_credit") return "Tarjeta";
  if (value === "food_benefit") return "Beneficio alimentación";
  if (value === "online") return "Online";
  return value || "Sin definir";
}

function formatStatus(value: string) {
  if (value === "pending") return "Pendiente";
  if (value === "ready") return "Listo";
  if (value === "completed") return "Completado";
  if (value === "cancelled" || value === "canceled") return "Cancelado";
  return value || "-";
}

function chileInputDate(date: Date) {
  const offset = date.getTimezoneOffset();
  const local = new Date(date.getTime() - offset * 60 * 1000);
  return local.toISOString().slice(0, 10);
}

function daysAgoInputDate(days: number) {
  const date = new Date();
  date.setDate(date.getDate() - days);
  return chileInputDate(date);
}

export default function AdminCompanyCustomersPage() {
  const today = useMemo(() => chileInputDate(new Date()), []);
  const defaultStart = useMemo(() => daysAgoInputDate(30), []);

  const [companies, setCompanies] = useState<Company[]>([]);
  const [bank, setBank] = useState<BankSettings>({
    businessName: "",
    rut: "",
    bank: "",
    accountType: "",
    accountNumber: "",
    email: "",
  });

  const [message, setMessage] = useState("");
  const [historyOpen, setHistoryOpen] = useState(false);
  const [historyLoading, setHistoryLoading] = useState(false);
  const [history, setHistory] = useState<CompanyHistory | null>(null);
  const [selectedCompanyId, setSelectedCompanyId] = useState<number | null>(null);
  const [historyStartDate, setHistoryStartDate] = useState(defaultStart);
  const [historyEndDate, setHistoryEndDate] = useState(today);

  async function load() {
    setMessage("");

    const [companiesResponse, bankResponse] = await Promise.all([
      fetch("/api/company-customers", { cache: "no-store" }),
      fetch("/api/company-bank-settings", { cache: "no-store" }),
    ]);

    const companiesData = await companiesResponse.json();
    const bankData = await bankResponse.json();

    if (companiesResponse.ok) {
      setCompanies(Array.isArray(companiesData) ? companiesData : []);
    }

    if (bankResponse.ok) {
      setBank(bankData);
    }
  }

  async function saveBankSettings() {
    const response = await fetch("/api/company-bank-settings", {
      method: "PUT",
      cache: "no-store",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(bank),
    });

    const data = await response.json();

    if (!response.ok) {
      setMessage(data.error || "No se pudieron guardar datos bancarios.");
      return;
    }

    setBank(data);
    setMessage("Datos bancarios guardados correctamente.");
  }

  async function loadCompanyHistory(companyId: number, startDate = historyStartDate, endDate = historyEndDate) {
    try {
      setHistoryLoading(true);
      setHistory(null);

      const params = new URLSearchParams();

      if (startDate) params.set("startDate", startDate);
      if (endDate) params.set("endDate", endDate);

      const response = await fetch(
        `/api/company-customers/${companyId}/history?${params.toString()}`,
        { cache: "no-store" }
      );

      const data = await response.json();

      if (!response.ok) {
        setMessage(data.error || "No se pudo cargar historial.");
        return;
      }

      setHistory(data);
    } catch (error) {
      console.error(error);
      setMessage("Error al cargar historial de compras.");
    } finally {
      setHistoryLoading(false);
    }
  }

  async function openCompanyHistory(companyId: number) {
    setSelectedCompanyId(companyId);
    setHistoryOpen(true);
    await loadCompanyHistory(companyId, historyStartDate, historyEndDate);
  }

  async function searchHistoryByDate() {
    if (!selectedCompanyId) return;
    await loadCompanyHistory(selectedCompanyId, historyStartDate, historyEndDate);
  }

  function setYesterdayRange() {
    const date = new Date();
    date.setDate(date.getDate() - 1);
    const yesterday = chileInputDate(date);
    setHistoryStartDate(yesterday);
    setHistoryEndDate(yesterday);

    if (selectedCompanyId) {
      loadCompanyHistory(selectedCompanyId, yesterday, yesterday);
    }
  }

  function setCurrentMonthRange() {
    const now = new Date();
    const firstDay = chileInputDate(new Date(now.getFullYear(), now.getMonth(), 1));
    const lastDay = chileInputDate(now);

    setHistoryStartDate(firstDay);
    setHistoryEndDate(lastDay);

    if (selectedCompanyId) {
      loadCompanyHistory(selectedCompanyId, firstDay, lastDay);
    }
  }

  useEffect(() => {
    load();
  }, []);

  return (
    <main className="min-h-screen text-zinc-950">
      <header className="mb-6 flex flex-wrap items-center justify-between gap-4">
        <div>
          <p className="text-xs font-black uppercase tracking-[0.25em] text-[#10B557]">
            Clientes
          </p>
          <h1 className="mt-1 text-4xl font-black">Empresas</h1>
          <p className="mt-1 text-sm font-bold text-zinc-500">
            Empresas registradas, consumo semanal, mensual e historial de compras.
          </p>
        </div>

        <div className="flex flex-wrap gap-3">
          <a
            href="/admin/customers"
            className="rounded-2xl border border-zinc-300 bg-white px-5 py-3 text-sm font-black"
          >
            Clientes personales
          </a>

          <a
            href="/pedido-empresas"
            className="rounded-2xl bg-[#10B557] px-5 py-3 text-sm font-black text-white"
          >
            Ver pedido empresas
          </a>
        </div>
      </header>

      {message && (
        <p className="mb-6 rounded-2xl bg-white p-4 text-sm font-black shadow-sm">
          {message}
        </p>
      )}

      <section className="mb-6 rounded-[2rem] bg-white p-6 shadow-sm">
        <h2 className="text-2xl font-black">Datos bancarios para transferencia</h2>

        <p className="mt-1 text-sm font-bold text-zinc-500">
          Estos datos aparecerán en la confirmación del pedido empresa.
        </p>

        <div className="mt-5 grid gap-4 md:grid-cols-3">
          {[
            ["businessName", "Razón social"],
            ["rut", "RUT"],
            ["bank", "Banco"],
            ["accountType", "Tipo de cuenta"],
            ["accountNumber", "Número de cuenta"],
            ["email", "Correo comprobante"],
          ].map(([key, label]) => (
            <label key={key}>
              <span className="text-xs font-black uppercase text-zinc-500">
                {label}
              </span>

              <input
                value={(bank as any)[key] || ""}
                onChange={(event) =>
                  setBank((current) => ({
                    ...current,
                    [key]: event.target.value,
                  }))
                }
                className="mt-2 w-full rounded-2xl border border-zinc-300 px-4 py-3 text-sm font-black"
              />
            </label>
          ))}
        </div>

        <button
          type="button"
          onClick={saveBankSettings}
          className="mt-5 rounded-2xl bg-zinc-950 px-6 py-3 text-sm font-black text-white"
        >
          Guardar datos bancarios
        </button>
      </section>

      <section className="rounded-[2rem] bg-white p-6 shadow-sm">
        <div className="flex flex-wrap items-end justify-between gap-4">
          <div>
            <h2 className="text-2xl font-black">Empresas registradas</h2>
            <p className="mt-1 text-sm font-bold text-zinc-500">
              El historial se calcula usando pedidos reales del reporte.
            </p>
          </div>

          <button
            type="button"
            onClick={load}
            className="rounded-2xl border border-zinc-300 bg-white px-5 py-3 text-sm font-black"
          >
            Actualizar
          </button>
        </div>

        <div className="mt-5 overflow-x-auto rounded-2xl border border-zinc-200">
          <table className="w-full min-w-[1200px] text-left text-sm">
            <thead className="bg-zinc-100">
              <tr>
                <th className="p-4 font-black">Empresa</th>
                <th className="p-4 font-black">Encargado</th>
                <th className="p-4 font-black">Pedidos</th>
                <th className="p-4 font-black">Esta semana</th>
                <th className="p-4 font-black">Este mes</th>
                <th className="p-4 font-black">Total comprado</th>
                <th className="p-4 font-black">Último pedido</th>
                <th className="p-4 font-black">Acción</th>
              </tr>
            </thead>

            <tbody>
              {companies.length === 0 ? (
                <tr>
                  <td colSpan={8} className="p-8 text-center font-bold text-zinc-500">
                    Aún no hay empresas registradas.
                  </td>
                </tr>
              ) : (
                companies.map((company) => (
                  <tr key={company.id} className="border-t border-zinc-100">
                    <td className="p-4">
                      <p className="font-black">{company.companyName}</p>
                      <p className="text-xs font-bold text-zinc-500">{company.rut}</p>
                      <p className="text-xs font-bold text-zinc-500">{company.giro}</p>
                      <p className="text-xs font-bold text-zinc-500">{company.address}</p>
                    </td>

                    <td className="p-4">
                      <p className="font-black">{company.contactName}</p>
                      <p className="text-xs font-bold text-zinc-500">{company.email}</p>
                      <p className="text-xs font-bold text-zinc-500">{company.phone}</p>
                    </td>

                    <td className="p-4 text-2xl font-black">
                      {company.orderCount}
                    </td>

                    <td className="p-4 text-lg font-black text-blue-600">
                      {formatPrice(company.weeklyTotal)}
                    </td>

                    <td className="p-4 text-lg font-black text-purple-600">
                      {formatPrice(company.monthlyTotal)}
                    </td>

                    <td className="p-4 text-lg font-black text-[#10B557]">
                      {formatPrice(company.totalPurchased)}
                    </td>

                    <td className="p-4 font-bold text-zinc-500">
                      {company.lastOrder
                        ? `#${company.lastOrder.orderNumber} · ${formatDate(company.lastOrder.createdAt)}`
                        : "-"}
                    </td>

                    <td className="p-4">
                      <button
                        type="button"
                        onClick={() => openCompanyHistory(company.id)}
                        className="rounded-2xl bg-zinc-950 px-5 py-3 text-sm font-black text-white"
                      >
                        Ver historial
                      </button>

                      <CompanyInvoicesAdminButton
                        companyId={company.id}
                        companyName={company.companyName}
                      />
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </section>

      {historyOpen && (
        <div className="fixed inset-0 z-[10000] flex items-center justify-center bg-black/50 px-4">
          <div className="max-h-[92vh] w-full max-w-6xl overflow-y-auto rounded-[2rem] bg-white p-6 shadow-2xl">
            <div className="mb-6 flex flex-wrap items-start justify-between gap-4">
              <div>
                <p className="text-xs font-black uppercase tracking-[0.25em] text-[#10B557]">
                  Historial de compras
                </p>

                <h2 className="mt-2 text-3xl font-black">
                  {history?.company?.companyName || "Empresa"}
                </h2>

                <p className="mt-1 text-sm font-bold text-zinc-500">
                  Consumo por rango de fechas, semanal, mensual y total histórico.
                </p>
              </div>

              <button
                type="button"
                onClick={() => {
                  setHistoryOpen(false);
                  setHistory(null);
                  setSelectedCompanyId(null);
                }}
                className="rounded-2xl border border-zinc-300 bg-white px-5 py-3 text-sm font-black"
              >
                Cerrar
              </button>
            </div>

            <section className="mb-6 rounded-3xl bg-zinc-50 p-5">
              <div className="grid gap-4 md:grid-cols-[1fr_1fr_auto_auto_auto]">
                <label>
                  <span className="text-xs font-black uppercase text-zinc-500">
                    Desde
                  </span>
                  <input
                    type="date"
                    value={historyStartDate}
                    onChange={(event) => setHistoryStartDate(event.target.value)}
                    className="mt-2 w-full rounded-2xl border border-zinc-300 bg-white px-4 py-3 text-sm font-black outline-none"
                  />
                </label>

                <label>
                  <span className="text-xs font-black uppercase text-zinc-500">
                    Hasta
                  </span>
                  <input
                    type="date"
                    value={historyEndDate}
                    onChange={(event) => setHistoryEndDate(event.target.value)}
                    className="mt-2 w-full rounded-2xl border border-zinc-300 bg-white px-4 py-3 text-sm font-black outline-none"
                  />
                </label>

                <div className="flex items-end">
                  <button
                    type="button"
                    onClick={searchHistoryByDate}
                    className="w-full rounded-2xl bg-[#10B557] px-5 py-3 text-sm font-black text-white"
                  >
                    Buscar
                  </button>
                </div>

                <div className="flex items-end">
                  <button
                    type="button"
                    onClick={setYesterdayRange}
                    className="w-full rounded-2xl border border-zinc-300 bg-white px-5 py-3 text-sm font-black"
                  >
                    Ayer
                  </button>
                </div>

                <div className="flex items-end">
                  <button
                    type="button"
                    onClick={setCurrentMonthRange}
                    className="w-full rounded-2xl border border-zinc-300 bg-white px-5 py-3 text-sm font-black"
                  >
                    Este mes
                  </button>
                </div>
              </div>
            </section>

            {historyLoading ? (
              <div className="rounded-3xl bg-zinc-50 p-10 text-center font-black text-zinc-500">
                Cargando historial...
              </div>
            ) : history ? (
              <>
                <div className="mb-6 grid gap-4 md:grid-cols-6">
                  <article className="rounded-3xl bg-zinc-950 p-5 text-white">
                    <p className="text-xs font-black uppercase opacity-80">
                      Rango seleccionado
                    </p>
                    <p className="mt-2 text-3xl font-black">
                      {formatPrice(history.summary.rangeTotal)}
                    </p>
                    <p className="mt-1 text-xs font-bold opacity-80">
                      {history.summary.rangeOrdersCount} pedidos
                    </p>
                  </article>

                  <article className="rounded-3xl bg-emerald-50 p-5">
                    <p className="text-xs font-black uppercase text-emerald-700">
                      Saldo disponible
                    </p>
                    <p className="mt-2 text-3xl font-black text-[#10B557]">
                      {formatPrice(Number((history.company as any).walletBalance || 0))}
                    </p>
                  </article>

                  <article className="rounded-3xl bg-blue-50 p-5">
                    <p className="text-xs font-black uppercase text-blue-700">
                      Esta semana
                    </p>
                    <p className="mt-2 text-3xl font-black text-blue-700">
                      {formatPrice(history.summary.weeklyTotal)}
                    </p>
                    <p className="mt-1 text-xs font-bold text-zinc-500">
                      {history.summary.weeklyOrdersCount} pedidos
                    </p>
                  </article>

                  <article className="rounded-3xl bg-purple-50 p-5">
                    <p className="text-xs font-black uppercase text-purple-700">
                      Este mes
                    </p>
                    <p className="mt-2 text-3xl font-black text-purple-700">
                      {formatPrice(history.summary.monthlyTotal)}
                    </p>
                    <p className="mt-1 text-xs font-bold text-zinc-500">
                      {history.summary.monthlyOrdersCount} pedidos
                    </p>
                  </article>

                  <article className="rounded-3xl bg-emerald-50 p-5">
                    <p className="text-xs font-black uppercase text-emerald-700">
                      Total histórico
                    </p>
                    <p className="mt-2 text-3xl font-black text-[#10B557]">
                      {formatPrice(history.summary.totalHistorical)}
                    </p>
                  </article>

                  <article className="rounded-3xl bg-yellow-50 p-5">
                    <p className="text-xs font-black uppercase text-yellow-700">
                      Ticket promedio
                    </p>
                    <p className="mt-2 text-3xl font-black text-yellow-700">
                      {formatPrice(history.summary.averageTicket)}
                    </p>
                  </article>
                </div>

                <div className="overflow-x-auto rounded-3xl border border-zinc-200">
                  <table className="w-full min-w-[1000px] text-left text-sm">
                    <thead className="bg-zinc-100">
                      <tr>
                        <th className="p-4 font-black">Pedido</th>
                        <th className="p-4 font-black">Fecha</th>
                        <th className="p-4 font-black">Programado</th>
                        <th className="p-4 font-black">Medio pago</th>
                        <th className="p-4 font-black">Estado</th>
                        <th className="p-4 font-black">Productos</th>
                        <th className="p-4 text-right font-black">Total</th>
                      </tr>
                    </thead>

                    <tbody>
                      {history.orders.length === 0 ? (
                        <tr>
                          <td colSpan={7} className="p-8 text-center font-bold text-zinc-500">
                            No hay pedidos de esta empresa en el rango seleccionado.
                          </td>
                        </tr>
                      ) : (
                        history.orders.map((order) => (
                          <tr key={order.id} className="border-t border-zinc-100 align-top">
                            <td className="p-4 font-black text-[#10B557]">
                              #{String(order.orderNumber).padStart(3, "0")}
                            </td>

                            <td className="p-4 font-bold">
                              {formatDate(order.createdAt)}
                            </td>

                            <td className="p-4 font-bold text-zinc-500">
                              {formatDate(order.scheduledFor)}
                            </td>

                            <td className="p-4 font-bold">
                              {formatPaymentMethod(order.paymentMethod)}
                            </td>

                            <td className="p-4 font-bold">
                              {formatStatus(order.status)}
                            </td>

                            <td className="p-4">
                              <div className="space-y-3">
                                {order.items.map((item) => (
                                  <div key={item.id} className="rounded-2xl bg-zinc-50 p-3">
                                    <div className="flex justify-between gap-3">
                                      <p className="font-black">
                                        {item.quantity}x {item.productName}
                                      </p>
                                      <p className="font-black">
                                        {formatPrice(item.total)}
                                      </p>
                                    </div>

                                    {item.modifiers.length > 0 && (
                                      <div className="mt-2 flex flex-wrap gap-2">
                                        {item.modifiers.map((modifier, index) => (
                                          <span
                                            key={`${item.id}-${modifier.optionName}-${index}`}
                                            className="rounded-full bg-white px-3 py-1 text-xs font-bold text-zinc-600"
                                          >
                                            {modifier.groupName}: {modifier.optionName}
                                          </span>
                                        ))}
                                      </div>
                                    )}
                                  </div>
                                ))}
                              </div>
                            </td>

                            <td className="p-4 text-right text-lg font-black text-[#10B557]">
                              {formatPrice(order.totalPaid)}
                            </td>
                          </tr>
                        ))
                      )}
                    </tbody>
                  </table>
                </div>
              </>
            ) : null}
          </div>
        </div>
      )}
    </main>
  );
}